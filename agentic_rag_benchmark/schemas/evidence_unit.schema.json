{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentic-rag.local/benchmark/schemas/evidence_unit.schema.json",
  "title": "EvidenceUnit",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "evidence_id",
    "doc_path",
    "section_key",
    "section_title",
    "canonical_text",
    "anchor",
    "source_hash",
    "extractor_version"
  ],
  "properties": {
    "evidence_id": {
      "type": "string",
      "minLength": 1
    },
    "doc_path": {
      "type": "string",
      "minLength": 1
    },
    "section_key": {
      "type": "string",
      "minLength": 1
    },
    "section_title": {
      "type": "string",
      "minLength": 1
    },
    "canonical_text": {
      "type": "string",
      "minLength": 1
    },
    "anchor": {
      "type": "string",
      "minLength": 1
    },
    "source_hash": {
      "type": "string",
      "minLength": 1
    },
    "extractor_version": {
      "type": "string",
      "minLength": 1
    }
  }
}
