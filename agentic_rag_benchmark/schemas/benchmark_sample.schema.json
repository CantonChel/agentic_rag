{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentic-rag.local/benchmark/schemas/benchmark_sample.schema.json",
  "title": "BenchmarkSample",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "sample_id",
    "question",
    "ground_truth",
    "ground_truth_contexts",
    "gold_evidence_refs",
    "tags",
    "difficulty",
    "suite_version"
  ],
  "properties": {
    "sample_id": {
      "type": "string",
      "minLength": 1
    },
    "question": {
      "type": "string",
      "minLength": 1
    },
    "ground_truth": {
      "type": "string",
      "minLength": 1
    },
    "ground_truth_contexts": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "gold_evidence_refs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "evidence_id",
          "doc_path",
          "section_key"
        ],
        "properties": {
          "evidence_id": {
            "type": "string",
            "minLength": 1
          },
          "doc_path": {
            "type": "string",
            "minLength": 1
          },
          "section_key": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "difficulty": {
      "type": "string",
      "minLength": 1
    },
    "suite_version": {
      "type": "string",
      "minLength": 1
    }
  }
}
