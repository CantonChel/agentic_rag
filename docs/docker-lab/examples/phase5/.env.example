APP_2_HOST_PORT=38082
DOCREADER_HOST_PORT=39090
MOCK_EMBEDDING_HOST_PORT=38089
MINIO_API_HOST_PORT=39000
MINIO_CONSOLE_HOST_PORT=39001
PG_PRIMARY_HOST_PORT=35432
PG_REPLICA_HOST_PORT=36432
REDIS_MASTER_HOST_PORT=36379
REDIS_REPLICA_HOST_PORT=36380
SENTINEL_1_HOST_PORT=26379
SENTINEL_2_HOST_PORT=26380
SENTINEL_3_HOST_PORT=26381

